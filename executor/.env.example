# EdgeOracle execution module — example env. Copy to .env (gitignored). NEVER commit real secrets.
# This slice is pure core (no keys, no chain): the KMS/relay/signer values below are placeholders
# for later phases and are NOT used yet.

# --- Master switch: nothing trades unless this is true (hard gate) ---
EDGE_EXEC_ENABLED=false

# --- Database (the executor's OWN db, isolated from the advisor's `edge`) ---
EDGE_EXEC_DATABASE_URL=postgresql+asyncpg://edge:edge@localhost:5432/edge_exec
# Set to run the DB-gated store tests against a throwaway db:
# EDGE_EXEC_TEST_DATABASE_URL=postgresql+asyncpg://edge:edge@localhost:5432/edge_exec_test

# --- Circuit breakers (Decimal money knobs) ---
EDGE_EXEC_HOT_WALLET_CAP_USD=500
EDGE_EXEC_PER_TRADE_CAP_USD=100
EDGE_EXEC_APPROVAL_THRESHOLD_USD=50
EDGE_EXEC_RATE_LIMIT_COUNT=10
EDGE_EXEC_RATE_LIMIT_WINDOW_S=60
EDGE_EXEC_RATE_LIMIT_NOTIONAL_USD=1000
EDGE_EXEC_MAX_SLIPPAGE=0.01

# --- Allowlists (csv). Enforced in breakers AND (later) independently in the signer ---
EDGE_EXEC_ALLOWLIST_CONTRACTS=
EDGE_EXEC_ALLOWLIST_SPENDERS=
EDGE_EXEC_ALLOWLIST_WITHDRAWALS=

# --- Redis (consume advisor signals; publish exec events) ---
EDGE_EXEC_REDIS_URL=redis://localhost:6379
EDGE_EXEC_SIGNALS_CHANNEL=edge:signals

# --- Later phases (placeholders; NOT used in the pure-core slice) ---
# KMS key handle is a non-secret id; KMS creds / relay auth come from a secret manager, NOT here.
EDGE_EXEC_CHAIN_ID=137
EDGE_EXEC_CLOB_API_BASE=https://clob.polymarket.com
EDGE_EXEC_RELAY_URL=
EDGE_EXEC_SIGNER_URL=
EDGE_EXEC_KMS_KEY_ID=
