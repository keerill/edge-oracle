# EdgeOracle quant — example env for the observability/alerting knobs.
# Copy to quant/.env and edit. app/config.py (Settings, EDGE_-prefixed) is the full source of
# truth for every knob; this file documents the observability surface added by that slice.
# NEVER commit a real Sentry DSN or any secret — use a secret manager in prod.

# --- Sentry (errors) — no-op when EDGE_SENTRY_DSN is unset (dev/test default) ---
# EDGE_SENTRY_DSN=
EDGE_SENTRY_ENVIRONMENT=dev

# --- Structured logging (JSON to stdout) ---
EDGE_LOG_LEVEL=INFO
EDGE_LOG_JSON=true            # false -> human-readable format for local tailing

# --- Prometheus metrics ---
# The FastAPI app serves GET /metrics. Each standalone CLI exposes its own endpoint on
# EDGE_METRICS_PORT; running several CLIs on one host needs distinct ports
# (e.g. 9100 poller, 9101 signals, 9102 streaming, 9103 monitor) — a bind clash is logged, not fatal.
EDGE_METRICS_ENABLED=true
EDGE_METRICS_PORT=9100

# --- Alerts (published to Redis edge:alerts -> dashboard toast + Sentry) ---
EDGE_ALERTS_CHANNEL=edge:alerts
EDGE_DRAWDOWN_ALERT_THRESHOLD=0.20       # peak-to-trough fraction
EDGE_CALIBRATION_DRIFT_THRESHOLD=0.05    # high-confidence claimed-vs-realized gap
EDGE_WS_DROP_ALERT_THRESHOLD=1           # reconnects before alerting (1 = any drop)
EDGE_MONITOR_INTERVAL_S=60               # monitor loop cadence (drawdown + drift)

# --- Backtest resolutions feed (the drawdown monitor + GET /backtest read this) ---
# EDGE_BACKTEST_RESOLUTIONS_PATH=/abs/path/to/demo_resolutions.json
