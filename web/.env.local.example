# Server-only. Used by the BFF routes + SSE streams (never shipped to the browser).
QUANT_API_URL=http://localhost:8000
REDIS_URL=redis://localhost:6379
# Redis channels — must match the quant EDGE_SIGNALS_CHANNEL / EDGE_ALERTS_CHANNEL.
SIGNALS_CHANNEL=edge:signals
ALERTS_CHANNEL=edge:alerts
# Executor control API (Phase 6-UI: the /approvals page). EXEC_API_KEY must match the executor's
# EDGE_EXEC_CONTROL_API_KEY when set. Server-only — the browser talks only to /api/exec/*.
EXEC_API_URL=http://localhost:8010
# EXEC_API_KEY=
